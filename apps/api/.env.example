# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/mcc

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
API_URL=https://your-api-domain.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ─── WhatsApp Business API ────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ─── Facebook Messenger ───────────────────────────────────────────────────────
MESSENGER_PAGE_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_WEBHOOK_VERIFY_TOKEN=

# ─── Media Storage (Cloudflare R2) ────────────────────────────────────────────
MEDIA_STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
MEDIA_STORAGE_BUCKET=mcc-media
MEDIA_STORAGE_ACCESS_KEY=
MEDIA_STORAGE_SECRET_KEY=
MEDIA_STORAGE_PUBLIC_URL=https://pub-xxx.r2.dev
