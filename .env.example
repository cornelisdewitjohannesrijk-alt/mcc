# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mcc?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ─── Meta / WhatsApp Business API ────────────────────────────────────────────
# Get these from Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# App Secret from: Meta Developer Console → Your App → Settings → Basic → App Secret
# This is DIFFERENT from the access token — used to verify webhook HMAC signatures
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-to-a-random-string

# ─── Meta / Facebook Messenger ───────────────────────────────────────────────
# Get these from Meta Developer Console → Your App → Messenger → Settings
MESSENGER_PAGE_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_WEBHOOK_VERIFY_TOKEN=change-this-to-a-random-string

# ─── Media Storage (Cloudflare R2 / S3-compatible) ───────────────────────────
MEDIA_STORAGE_ENDPOINT=
MEDIA_STORAGE_BUCKET=
MEDIA_STORAGE_ACCESS_KEY=
MEDIA_STORAGE_SECRET_KEY=
MEDIA_STORAGE_PUBLIC_URL=

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
